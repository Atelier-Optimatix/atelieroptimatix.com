---
import type { CollectionEntry } from "astro:content";
import WorkLayout from "@/layouts/WorkLayout.astro";
import { getCollectionStaticPaths } from "@/lib/collection-helpers";

export interface Props {
	data: CollectionEntry<"works">;
}

export async function getStaticPaths() {
	const paths = await getCollectionStaticPaths("works", "es");
	// EduConnect's case study now lives at /es/educonnect-description instead.
	return paths.filter((path) => path.params.slug !== "educonnect");
}

const { data: work } = Astro.props;
const { Content } = await work.render();
---

<WorkLayout frontmatter={work}>
	<Content />
</WorkLayout>
