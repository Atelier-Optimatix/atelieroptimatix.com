<script>
	function initEduConnectReel() {
		const scroller = document.getElementById("ec-scroller");
		if (!scroller || (scroller as HTMLElement).dataset.ecInit) return;
		(scroller as HTMLElement).dataset.ecInit = "1";

		const slides = Array.from(scroller.querySelectorAll<HTMLElement>(".ec-slide"));

		function animateCounters(slide: HTMLElement) {
			slide.querySelectorAll<HTMLElement>(".ec-cnt").forEach((el) => {
				const cap = Number(el.dataset.cap ?? 0);
				const suf = el.dataset.suf ?? "";
				const start = performance.now();
				const dur = 1400;
				function step(now: number) {
					const p = Math.min(1, (now - start) / dur);
					const eased = 1 - (1 - p) ** 3;
					el.textContent = Math.round(cap * eased) + suf;
					if (p < 1) requestAnimationFrame(step);
				}
				requestAnimationFrame(step);
			});
		}

		function animateGauge(slide: HTMLElement) {
			const arc = slide.querySelector<SVGCircleElement>(".ec-gauge-arc");
			const num = slide.querySelector<SVGTextElement>(".ec-gauge-num");
			if (!arc || !num) return;
			const C = 2 * Math.PI * 150;
			const target = 0.82;
			const start = performance.now();
			const dur = 1400;
			function step(now: number) {
				const p = Math.min(1, (now - start) / dur);
				const eased = 1 - (1 - p) ** 3;
				arc.setAttribute(
					"stroke-dasharray",
					`${C * target * eased} ${C}`,
				);
				num.textContent = String(Math.round(82 * eased));
				if (p < 1) requestAnimationFrame(step);
			}
			requestAnimationFrame(step);
		}

		const io = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					const slide = entry.target as HTMLElement;
					if (entry.isIntersecting && entry.intersectionRatio >= 0.55) {
						if (slide.classList.contains("is-active")) continue;
						slide.classList.add("is-active");
						if (slide.querySelector(".ec-cnt")) animateCounters(slide);
						if (slide.querySelector(".ec-gauge-arc")) animateGauge(slide);
					} else {
						slide.classList.remove("is-active");
					}
				}
			},
			{ root: scroller, threshold: [0, 0.55, 1] },
		);

		for (const slide of slides) io.observe(slide);
	}

	document.addEventListener("astro:page-load", initEduConnectReel);
</script>
